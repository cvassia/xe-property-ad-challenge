generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Ad {
  id                String   @id @default(cuid())
  title             String
  type              String
  price             Int
  description       String?

  propertyCategory  String   @default("apartment")
  apartmentType     String?
  squareMeters      Int      @default(1)
  energyClass       String   @default("unknown")
  floor             String?
  bedrooms          Int?
  bathrooms         Int?
  constructionYear  Int?
  renovationYear    Int?
  condition         String?
  contactPhone String @default("")

  areaPlaceId       String
  areaMainText      String
  areaSecondaryText String

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}